{
    "name": "fluorite",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc --build && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "po:extract": "lingui extract",
        "po:compile": "lingui compile --typescript",
        "test": "vitest",
        "coverage": "vitest run --coverage",
        "format": "prettier --write .",
        "lighthouse": "lhci autorun",
        "prepare": "husky"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": "^24",
            "onFail": "error"
        }
    },
    "dependencies": {
        "@headlessui/react": "^2.2.10",
        "@lingui/core": "^6.4.0",
        "@lingui/detect-locale": "^6.4.0",
        "@lingui/react": "^6.4.0",
        "@tailwindcss/vite": "^4.3.1",
        "@vercel/analytics": "^2.0.1",
        "jotai": "^2.20.1",
        "jotai-effect": "^2.3.1",
        "mediainfo.js": "^0.3.7",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-icons": "^5.6.0",
        "tailwindcss": "^4.3.1"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@eslint/js": "^9.39.2",
        "@lhci/cli": "^0.15.1",
        "@lingui/babel-plugin-lingui-macro": "^6.4.0",
        "@lingui/cli": "^6.4.0",
        "@lingui/vite-plugin": "^6.4.0",
        "@rolldown/plugin-babel": "^0.2.3",
        "@types/babel__core": "^7.20.5",
        "@types/node": "^25.9.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vite-pwa/assets-generator": "^1.0.2",
        "@vitejs/devtools": "^0.3.3",
        "@vitejs/plugin-react": "^6.0.3",
        "@vitest/coverage-v8": "^4.1.9",
        "@vitest/ui": "^4.1.9",
        "eslint": "^9.39.2",
        "eslint-plugin-lingui": "^0.14.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "prettier": "^3.8.4",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.1.0",
        "vite-plugin-pwa": "^1.3.0",
        "vite-plugin-sri-gen": "^1.6.1",
        "vitest": "^4.1.9",
        "workbox-window": "^7.4.1"
    }
